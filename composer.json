{
	"name"        : "iandunn/wp-cli-network-users",
	"description" : "WP-CLI commands for managing users across a WordPress Multisite network",
	"type"        : "wordpress-plugin",
	"homepage"    : "https://github.com/iandunn/wp-cli-network-users",
	"license"     : "GPL-2.0-only",

	"keywords" : [ "wp-cli", "wordpress", "multisite", "users" ],

	"support" : {
		"issues" : "https://github.com/iandunn/wp-cli-network-users/issues",
		"source"  : "https://github.com/iandunn/wp-cli-network-users"
	},

	"authors" : [
		{
			"name"     : "Ian Dunn",
			"email"    : "ian@iandunn.name",
			"homepage" : "https://iandunn.name"
		}
	],

	"autoload" : {
		"files" : [ "wp-cli-network-users.php" ]
	},

	"require-dev" : {
		"wp-cli/wp-cli-tests"   : "^4.2",
		"wp-cli/entity-command"    : "^2",
		"wp-cli/super-admin-command" : "^1",
		"liuggio/fastest"       : "^1.9"
	},

	"scripts" : {
		"test"          : [ "Composer\\Config::disableProcessTimeout", "bin/test" ],
		"test-rerun"    : [ "Composer\\Config::disableProcessTimeout", "bin/test --serial --rerun" ],
		"test-serial"   : [ "Composer\\Config::disableProcessTimeout", "bin/test --serial" ],
		"prepare-tests" : "install-package-tests"
	},

	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
